{
	"name": "express-typescript-boilerplate",
	"version": "1.0.14",
	"description": "An Express boilerplate backend",
	"author": "Edwin Hernandez",
	"repository": "edwinhern/express-typescript-2024",
	"license": "MIT",
	"main": "index.ts",
	"private": true,
	"type":"module",
	"scripts": {
		"build": "prisma generate && tsc && tsup",
		"dev": "prisma generate && tsx watch src/index.ts",
		"start": "node dist/index.js",
		"start:prod": "node dist/index.js",
		"seed": "node --import=tsx prisma/seed.ts",
		"check": "biome check --write",
		"test": "vitest run",
		"test:cov": "vitest run --coverage"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@types/bcryptjs": "^2.4.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/pg": "^8.20.0",
		"bcryptjs": "^3.0.3",
		"cors": "2.8.6",
		"dotenv": "17.3.1",
		"express": "5.2.1",
		"express-rate-limit": "8.3.1",
		"helmet": "8.1.0",
		"http-status-codes": "2.3.0",
		"jsonwebtoken": "^9.0.3",
		"pg": "^8.22.0",
		"pino": "9.14.0",
		"pino-http": "10.5.0",
		"resend": "^6.17.2",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/cors": "2.8.19",
		"@types/express": "5.0.3",
		"@types/supertest": "6.0.3",
		"@types/swagger-ui-express": "4.1.8",
		"@vitest/coverage-v8": "3.2.4",
		"pino-pretty": "13.1.3",
		"prisma": "^7.8.0",
		"supertest": "7.1.4",
		"tsup": "8.5.1",
		"tsx": "4.21.0",
		"typescript": "5.9.2",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "3.2.4"
	},
	"tsup": {
		"entry": [
			"src/index.ts",
			"src/vercel-handler.ts"
		],
		"outDir": "dist",
		"format": [
			"cjs"
		],
		"target": "es2020",
		"sourcemap": true,
		"clean": true,
		"splitting": false,
		"skipNodeModulesBundle": true
	},
	"packageManager": "pnpm@10.33.0"
}
