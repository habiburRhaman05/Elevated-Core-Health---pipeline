generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  va
}

enum PatientStage {
  onboarding
  visit_complete
  post_visit_docs
  chart_signed
  sent_to_billing
  payment_posted
  reconciled
}

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  passwordHash         String    @map("password_hash")
  role                 UserRole  @default(va)
  shift                String?
  passwordResetToken   String?   @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  createdAt            DateTime  @default(now()) @map("created_at")

  assignedPatients     Patient[]     @relation("PatientAssignedTo")
  flaggedPatients      Patient[]     @relation("PatientFlaggedBy")
  flagClearedPatients  Patient[]     @relation("PatientFlagClearedBy")
  updatedPatients      Patient[]     @relation("PatientUpdatedBy")
  refreshTokens    RefreshToken[]

  @@map("users")
}

model Patient {
  id                  String       @id @default(uuid())
  name                String
  email               String?
  phone               String?
  stage               PatientStage @default(onboarding)
  assignedTo          String?      @map("assigned_to")
  notes               String?
  checklistState      Json         @default("{}") @map("checklist_state")
  isFlagged           Boolean      @default(false) @map("is_flagged")
  flagReason          String?      @map("flag_reason")
  flaggedById         String?      @map("flagged_by")
  flaggedAt           DateTime?    @map("flagged_at")
  flagClearedReason   String?      @map("flag_cleared_reason")
  flagClearedById     String?      @map("flag_cleared_by")
  flagClearedAt       DateTime?    @map("flag_cleared_at")
  source              String       @default("manual")
  bookingPlatform     String?      @map("booking_platform")
  appointmentDatetime DateTime?    @map("appointment_datetime")
  problemDescription  String?      @map("problem_description")
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at")
  updatedById         String?      @map("updated_by")
  createdAt           DateTime     @default(now()) @map("created_at")

  assignedUser       User?  @relation("PatientAssignedTo", fields: [assignedTo], references: [id])
  flaggedByUser      User?  @relation("PatientFlaggedBy", fields: [flaggedById], references: [id])
  flagClearedByUser  User?  @relation("PatientFlagClearedBy", fields: [flagClearedById], references: [id])
  updatedByUser      User?  @relation("PatientUpdatedBy", fields: [updatedById], references: [id])

  activityLogs ActivityLog[]

  @@index([stage])
  @@index([isFlagged])
  @@index([updatedAt])
  @@map("patients")
}

model ActivityLog {
  id        String   @id @default(uuid())
  patientId String   @map("patient_id")
  author    String
  message   String
  type      String
  createdAt DateTime @default(now()) @map("created_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([createdAt])
  @@map("activity_log")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ChecklistItem {
  id          String       @id @default(uuid())
  stage       PatientStage
  label       String
  description String?
  isDefault   Boolean      @default(false) @map("is_default")
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@unique([stage, label])
  @@index([stage])
  @@map("checklist_items")
}
